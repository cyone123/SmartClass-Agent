# SmartClass Docker deployment environment.
# Copy this file to `.env.docker` and replace placeholder secrets before running:
#   docker compose --env-file .env.docker up -d --build

# Public ports
FRONTEND_BIND=0.0.0.0
DEBUG_BIND=127.0.0.1
FRONTEND_PORT=8080
BACKEND_PORT=8000
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
ONLYOFFICE_PORT=8082
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# Public URL used by backend-generated download, preview, and OnlyOffice callback URLs.
# Local single-machine default:
PUBLIC_API_BASE_URL=http://localhost:8080

# Database
POSTGRES_DB=smartclass
POSTGRES_USER=smartclass
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql://smartclass:replace-with-a-strong-database-password@postgres:5432/smartclass
SQLALCHEMY_ECHO=false

# Authentication
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=86400

# Main model
MODEL=
API_KEY=
BASE_URL=

# Embeddings
EMBEDDINGS_MODEL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=

# Structured output model
STRUCTED_MDOEL=
STRUCTED_API_KEY=
STRUCTED_BASE_URL=
STRUCTURED_TIMEOUT_MS=30000
STRUCTURED_WARMUP_ENABLED=true
STRUCTURED_FALLBACK_ENABLED=true
STRUCTURED_PROMPT_CACHE_ENABLED=false

# Small/fast model
SMALL_MDOEL=
SMALL_API_KEY=
SMALL_BASE_URL=

# Follow-up suggestions
SUGGESTION_MODEL=
SUGGESTION_API_KEY=
SUGGESTION_BASE_URL=

# Long-term memory reflection and selection
MEMORY_MODEL=
MEMORY_API_KEY=
MEMORY_BASE_URL=
STRUCTURED_FAST_MODEL=
STRUCTURED_FAST_API_KEY=
STRUCTURED_FAST_BASE_URL=

# Speech and video
STT_MODEL=
STT_BASE_URL=
STT_API_KEY=
STT_LANGUAGE=
VIDEO_VISION_MODEL=
VIDEO_VISION_BASE_URL=
VIDEO_VISION_API_KEY=
VIDEO_FFMPEG_BIN=ffmpeg

# File limits
FILE_UPLOAD_MAX_SIZE_BYTES=20971520
KNOWLEDGE_FILE_ALLOWED_EXTENSIONS=.docx,.pdf,.txt,.md,.markdown,.csv,.json
ATTACHMENT_FILE_ALLOWED_EXTENSIONS=.docx,.pdf,.mp4
VOICE_FILE_ALLOWED_EXTENSIONS=.webm,.wav,.mp3,.m4a,.mp4,.ogg

# Storage
FILE_STORAGE_ROOT=/app/storage
NODE_PATH=/app/node_modules
STORAGE_BACKEND=minio
STORAGE_DOWNLOAD_MODE=proxy
STORAGE_PRESIGNED_URL_TTL_SECONDS=900
MINIO_ROOT_USER=smartclass
MINIO_ROOT_PASSWORD=replace-with-a-strong-minio-password
MINIO_BUCKET=smartclass
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=smartclass
MINIO_SECRET_KEY=replace-with-a-strong-minio-password
MINIO_REGION=
MINIO_SECURE=false

# Agent workspace execution
WORKSPACE_EXECUTION_BACKEND=local
DAYTONA_API_KEY=
DAYTONA_API_URL=
DAYTONA_TARGET=
DAYTONA_SNAPSHOT=
DAYTONA_IMAGE=
DAYTONA_CLEANUP_POLICY=delete
DAYTONA_NETWORK_BLOCK_ALL=true
DAYTONA_NETWORK_ALLOW_LIST=
DAYTONA_AUTO_STOP_INTERVAL_MINUTES=15
DAYTONA_AUTO_ARCHIVE_INTERVAL_MINUTES=1440
DAYTONA_AUTO_DELETE_INTERVAL_MINUTES=10080
DAYTONA_CREATE_TIMEOUT_SECONDS=60
DAYTONA_EXECUTION_TIMEOUT_SECONDS=120
DAYTONA_FILE_SYNC_TIMEOUT_SECONDS=1800
DAYTONA_REMOTE_ROOT=/workspace/smartclass

# Observability
OBSERVABILITY_ENABLED=true
OBSERVABILITY_LOG_LEVEL=info
OBSERVABILITY_TRACE_JSONL_ENABLED=false
OBSERVABILITY_MAX_FIELD_CHARS=1000
OBSERVABILITY_MAX_JSONL_BYTES_PER_EVENT=20000

OTEL_ENABLED=true
OTEL_SERVICE_NAME=smartclass-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_EXPORTER_OTLP_INSECURE=true
DEPLOYMENT_ENVIRONMENT=docker

PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_HISTOGRAM_BUCKETS=0.05,0.1,0.25,0.5,1,2.5,5,10,30,60
PROMETHEUS_EXPORT_MODE=endpoint

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password
